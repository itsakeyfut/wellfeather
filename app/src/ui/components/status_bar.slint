// Status bar — displayed at the bottom of the main window.
// Left: active connection name (and DB) or "Not connected".
// Right: query lifecycle status — "Running…", "N ms · M rows", "Cancelled", "Error: …".

import { Colors, Typography, Layout } from "../theme.slint";

export component StatusBar inherits Rectangle {
    background: Colors.crust;

    /// Text shown on the left: active connection name (and DB) or "Not connected".
    /// Updated from Rust via invoke_from_event_loop on Event::Connected / Event::Disconnected.
    in property <string> connection-text;
    /// Query lifecycle status string pushed from Rust (status-message in UiState).
    /// Examples: "Running…"  |  "42 ms  ·  128 rows"  |  "Cancelled"  |  "Error: …"
    in property <string> query-status;

    HorizontalLayout {
        padding-left:  Layout.padding-md;
        padding-right: Layout.padding-md;
        spacing: Layout.spacing-lg;

        Text {
            text: root.connection-text;
            color: Colors.subtext0;
            font-size: Typography.size-base;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        Text {
            text: root.query-status;
            color: Colors.subtext0;
            font-size: Typography.size-base;
            vertical-alignment: center;
        }
    }
}
