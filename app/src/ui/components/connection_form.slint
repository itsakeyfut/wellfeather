// Connection form component.
// Receives all state as properties bound from UiState in app.slint.
// Does not import UiState directly to avoid circular imports
// (app.slint imports this file; UiState is defined in app.slint).

import { Colors, Typography, Layout, Icons } from "../theme.slint";
import { ActionButton } from "common.slint";

// ── Helper: labelled text field row ──────────────────────────────────────────

component FieldRow inherits HorizontalLayout {
    in property <string>     label-text;
    in property <string>     placeholder: "";
    in property <bool>       is-password: false;
    in-out property <string> value;

    // Fired with +1 (Down/Tab/Return) or -1 (Up/Shift+Tab) to move to the next/prev field.
    callback move-focus(int);
    public function grab-focus() { field-input.focus(); }

    spacing: Layout.spacing-lg;
    Text {
        text: label-text;
        color: Colors.subtext0;
        width: 80px;
        vertical-alignment: center;
    }
    Rectangle {
        horizontal-stretch: 1;
        background: Colors.base;
        border-radius: Layout.radius-md;
        height: Layout.height-row;
        // Placeholder overlaid at the same position as TextInput.
        // Rendered first (behind) so TextInput stays on top and receives focus.
        // Not shown for password fields.
        if !is-password && root.placeholder != "" && root.value == "": Text {
            x: Layout.padding-input;
            y: 0;
            width: parent.width - Layout.padding-input * 2;
            height: parent.height;
            text: root.placeholder;
            color: Colors.surface2;
            vertical-alignment: center;
        }
        // TextInput rendered last → on top → receives all pointer/focus events.
        field-input := TextInput {
            x: Layout.padding-input;
            y: 0;
            width: parent.width - Layout.padding-input * 2;
            height: parent.height;
            vertical-alignment: center;
            text <=> value;
            color: Colors.text;
            input-type: is-password ? InputType.password : InputType.text;
            key-pressed(event) => {
                if (event.text == Key.DownArrow
                        || (event.text == Key.Tab && !event.modifiers.shift)
                        || event.text == Key.Return) {
                    root.move-focus(1);
                    EventResult.accept
                } else if (event.text == Key.UpArrow
                           || (event.text == Key.Tab && event.modifiers.shift)) {
                    root.move-focus(-1);
                    EventResult.accept
                } else {
                    EventResult.reject
                }
            }
        }
    }
}

// ── Helper: tab button with underline ────────────────────────────────────────

component TabButton inherits VerticalLayout {
    in property <string> label-text;
    in property <bool>   active;
    callback clicked;

    horizontal-stretch: 1;
    Text {
        text: label-text;
        color: active ? Colors.blue : Colors.subtext0;
        horizontal-alignment: center;
        vertical-alignment: center;
        height: Layout.height-row;
    }
    Rectangle {
        height: 2px;
        background: active ? Colors.blue : Colors.surface1;
    }
    TouchArea { clicked => { root.clicked(); } }
}

// ── Helper: DB type toggle button ────────────────────────────────────────────

component DbTypeButton inherits Rectangle {
    in property <string> label-text;
    in property <image>  icon;
    in property <bool>   active;
    in property <string> ui-font: Typography.font-ui;
    callback clicked;

    background: active ? Colors.blue : Colors.surface1;
    border-radius: Layout.radius-md;
    height: Layout.height-btn-lg;
    horizontal-stretch: 1;
    // Wrapping Image in a Rectangle with explicit width prevents Slint from using
    // the SVG's intrinsic size (800px) in the alignment: center group calculation.
    HorizontalLayout {
        alignment: center;
        spacing: Layout.spacing-md;
        Rectangle {
            width: root.icon.width > 0 ? Layout.icon-xl : 0;
            horizontal-stretch: 0;
            Image {
                width: parent.width;
                height: parent.height;
                source: root.icon;
                image-fit: contain;
            }
        }
        Text {
            text: label-text;
            color: active ? Colors.base : Colors.text;
            font-size: Typography.size-xl;
            font-family: root.ui-font;
            vertical-alignment: center;
            wrap: no-wrap;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// ── Connection form ───────────────────────────────────────────────────────────

export component ConnectionForm inherits Rectangle {
    // ── Properties bound from UiState in app.slint ───────────────────────────
    in property <string>  ui-font:     "Segoe UI"; // platform system font, passed from app.slint
    in-out property <int> tab-index:   0;
    in-out property <int>    db-type:     0;
    in-out property <string> name:        "";
    in-out property <string> conn-string: "";
    in-out property <string> host:        "";
    in-out property <string> port:        "";
    in-out property <string> user:        "";
    in-out property <string> password:    "";
    in-out property <string> database:    "";
    in-out property <string> status:      "";
    in-out property <bool>   testing:     false;
    /// Set to true after a successful Test Connection; resets to false when the
    /// form is opened or a new test is started.  Used to decide whether Add
    /// shows a confirmation dialog.
    in property <bool> test-ok: false;
    /// True when editing an existing connection (title + button label change).
    in property <bool> is-edit: false;

    callback cancel();
    callback test-connection();
    callback add-connection();
    callback delete-connection();

    // Auto-focus the Name field when the form opens and whenever the active tab changes.
    init => { name-field.grab-focus(); }
    changed tab-index => { name-field.grab-focus(); }

    // ── Layout ────────────────────────────────────────────────────────────────
    background: Colors.surface0;
    border-radius: Layout.radius-lg;
    border-width: 1px;
    border-color: Colors.surface2;
    drop-shadow-blur: 24px;
    drop-shadow-color: Colors.shadow-light;
    width: 660px;
    height: 520px;
    clip: true;

    VerticalLayout {
        padding: Layout.padding-xl;
        spacing: Layout.spacing-xl;

        // Title
        Text {
            text: root.is-edit ? @tr("Edit Connection") : @tr("Add Connection");
            color: Colors.text;
            font-size: Typography.size-2xl;
            font-weight: 700;
        }

        // Name
        name-field := FieldRow {
            label-text: @tr("Name");
            placeholder: @tr("My Database");
            value <=> root.name;
            move-focus(d) => {
                if (d > 0) {
                    if (root.tab-index == 0) { conn-string-input.focus(); }
                    else { host-field.grab-focus(); }
                }
                // d < 0: Name is the first field — do nothing.
            }
        }

        // DB type selector
        HorizontalLayout {
            spacing: Layout.spacing-md;
            DbTypeButton {
                label-text: "PostgreSQL";
                icon: Icons.brand-postgresql;
                active: root.db-type == 0;
                ui-font: root.ui-font;
                clicked => { root.db-type = 0; }
            }
            DbTypeButton {
                label-text: "MySQL";
                icon: Icons.brand-mysql;
                active: root.db-type == 1;
                ui-font: root.ui-font;
                clicked => { root.db-type = 1; }
            }
            DbTypeButton {
                label-text: "SQLite";
                icon: Icons.brand-sqlite;
                active: root.db-type == 2;
                ui-font: root.ui-font;
                clicked => { root.db-type = 2; }
            }
        }

        // Tab bar
        HorizontalLayout {
            TabButton {
                label-text: @tr("Connection String");
                active: root.tab-index == 0;
                clicked => { root.tab-index = 0; }
            }
            TabButton {
                label-text: @tr("Individual Fields");
                active: root.tab-index == 1;
                clicked => { root.tab-index = 1; }
            }
        }

        // Spacer — pushes tab content + status + buttons toward the bottom of the dialog.
        Rectangle { vertical-stretch: 1; }

        // ── Tab content (single panel for both tabs) ─────────────────────────
        // Using one panel instead of two eliminates the phantom 10px spacing that
        // a 0-height sibling would introduce, moving the conn-string input lower.
        // Height always equals the Individual Fields preferred height so the flex
        // spacer above distributes equally for both tabs.
        Rectangle {
            height: fields-layout.preferred-height;
            clip: true;

            // Connection String tab — input pinned to the bottom of the panel,
            // aligned with the Database field in the Individual Fields tab.
            Rectangle {
                visible: root.tab-index == 0;
                background: Colors.base;
                border-radius: Layout.radius-md;
                width: parent.width;
                height: Layout.height-row;
                y: parent.height - Layout.height-row;

                if root.conn-string == "": Text {
                    x: Layout.padding-input;
                    y: 0;
                    width: parent.width - Layout.padding-input * 2;
                    height: Layout.height-row;
                    text: "postgres://user:pass@host:5432/db";
                    color: Colors.surface2;
                    vertical-alignment: center;
                }
                conn-string-input := TextInput {
                    x: Layout.padding-input;
                    y: 0;
                    width: parent.width - Layout.padding-input * 2;
                    height: Layout.height-row;
                    vertical-alignment: center;
                    text <=> root.conn-string;
                    color: Colors.text;
                    key-pressed(event) => {
                        if (event.text == Key.UpArrow
                                || (event.text == Key.Tab && event.modifiers.shift)) {
                            name-field.grab-focus();
                            EventResult.accept
                        } else if (event.text == Key.Escape) {
                            root.cancel();
                            EventResult.accept
                        } else {
                            EventResult.reject
                        }
                    }
                }
            }

            // Individual Fields tab
            fields-layout := VerticalLayout {
                visible: root.tab-index == 1;
                spacing: Layout.spacing-md;

                host-field := FieldRow {
                    label-text: @tr("Host");
                    placeholder: "localhost";
                    value <=> root.host;
                    move-focus(d) => {
                        if (d > 0) { port-field.grab-focus(); }
                        else { name-field.grab-focus(); }
                    }
                }
                port-field := FieldRow {
                    label-text: @tr("Port");
                    placeholder: "5432";
                    value <=> root.port;
                    move-focus(d) => {
                        if (d > 0) { user-field.grab-focus(); }
                        else { host-field.grab-focus(); }
                    }
                }
                user-field := FieldRow {
                    label-text: @tr("User");
                    placeholder: @tr("username");
                    value <=> root.user;
                    move-focus(d) => {
                        if (d > 0) { pass-field.grab-focus(); }
                        else { port-field.grab-focus(); }
                    }
                }
                pass-field := FieldRow {
                    label-text: @tr("Password");
                    value <=> root.password;
                    is-password: true;
                    move-focus(d) => {
                        if (d > 0) { db-field.grab-focus(); }
                        else { user-field.grab-focus(); }
                    }
                }
                db-field := FieldRow {
                    label-text: @tr("Database");
                    placeholder: @tr("database name");
                    value <=> root.database;
                    move-focus(d) => {
                        if (d < 0) { pass-field.grab-focus(); }
                    }
                }
            }
        }

        // Status message (shown only when not empty)
        HorizontalLayout {
            height: Layout.height-btn-sm;
            spacing: Layout.spacing-icon;
            if root.status != "" : Image {
                width: Layout.icon-md;
                source: Icons.alert-error;
                colorize: Colors.red;
                image-fit: contain;
            }
            Text {
                text: root.status;
                color: root.status == "" ? transparent : Colors.red;
                font-size: Typography.size-base;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }
        }

        // Buttons
        HorizontalLayout {
            spacing: Layout.spacing-lg;
            alignment: end;

            if root.is-edit : ActionButton {
                width: 100px;
                text: @tr("Delete");
                bg: Colors.red;
                fg: Colors.base;
                leading-icon: Icons.delete;
                enabled: !root.testing;
                clicked => { root.delete-connection(); }
            }

            ActionButton {
                width: 80px;
                text: @tr("Cancel");
                clicked => { root.cancel(); }
            }

            ActionButton {
                width: 160px;
                text: root.testing ? @tr("Testing\u{2026}") : @tr("Test Connection");
                bg: root.testing ? Colors.surface2 : Colors.blue;
                fg: root.testing ? Colors.subtext0 : Colors.base;
                leading-icon: Icons.test-connection;
                enabled: !root.testing;
                clicked => { root.test-connection(); }
            }

            // Save — only in edit mode, with confirm icon
            if root.is-edit : ActionButton {
                width: 90px;
                text: @tr("Save");
                bg: root.testing ? Colors.surface2
                  : root.test-ok  ? Colors.green
                  :                 Colors.overlay0;
                fg: root.testing ? Colors.subtext0 : Colors.base;
                leading-icon: Icons.confirm;
                enabled: !root.testing;
                clicked => { root.add-connection(); }
            }

            // Add — only when creating a new connection
            if !root.is-edit : ActionButton {
                width: 80px;
                text: @tr("Add");
                bg: root.testing ? Colors.surface2
                  : root.test-ok  ? Colors.green
                  :                 Colors.overlay0;
                fg: root.testing ? Colors.subtext0 : Colors.base;
                enabled: !root.testing;
                clicked => { root.add-connection(); }
            }
        }
    }
}
