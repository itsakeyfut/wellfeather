// Shared value types used by multiple components.
// Keep only structs here — globals defined in non-root files are not
// included in the Slint-generated Rust bindings, so UiState lives in app.slint.

export struct ConnectionEntry {
    id: string,
    name: string,
    db-type: string,   // "PostgreSQL" | "MySQL" | "SQLite"
    is-active: bool,
}

/// One cell in a result row.  is-null distinguishes SQL NULL from an empty string.
export struct RowCellData {
    value:   string,
    is-null: bool,
}

export struct RowData {
    cells: [RowCellData],
}

export struct SidebarNode {
    id: string,           // "conn:{id}" | "cat:{id}:{name}" | "item:{id}:{kind}:{name}"
    label: string,
    sub-label: string,    // db-type badge for connections; "" otherwise
    level: int,           // 0=connection, 1=category, 2=item
    is-expanded: bool,
    is-active: bool,      // true for the active connection (level 0 only)
    is-read-only: bool,   // true for connections with read_only=true
    node-kind: string,    // "connection" | "category" | "table" | "view" | "proc" | "index"
    parent-index: int,    // flat-list index of parent node; -1 for root connection nodes
    visible: bool,        // animation: false = collapsed (height 0), true = expanded
    stagger-delay: int,   // animation: ms delay for enter stagger (0 for non-item nodes)
}

export struct CompletionRow {
    label: string,
    kind: string,
    detail: string,
    insert-text: string,
    cursor-offset: int,
    table-name: string,
}

export struct TabEntry {
    id: string,
    title: string,
    kind: string,   // "sql-editor" | "table-view"
}

export struct ColumnData {
    name: string,
    data-type: string,
    nullable: bool,
}

export struct SnippetEntry {
    id: string,
    name: string,
    comment: string,
    sql: string,
}

export struct MetadataSearchResult {
    kind: string,       // "table" | "view" | "column"
    label: string,      // "users" or "users.name"
    detail: string,     // "" or "VARCHAR(255)"
    table-name: string, // parent table name (= label for tables/views)
}

/// One syntax-highlight span rendered as a colored Text element over the editor text.
/// kind: 0=keyword, 1=string-literal, 2=comment, 3=number, 4=identifier (gap fill)
export struct HighlightSpan {
    line: int,
    col:  int,
    text: string,
    kind: int,
}
