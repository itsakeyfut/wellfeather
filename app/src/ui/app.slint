import { ConnectionEntry, RowData } from "globals.slint";
import { ConnectionForm }  from "components/connection_form.slint";
import { Sidebar }         from "components/sidebar.slint";
import { Editor }          from "components/editor.slint";
import { ResultTable }     from "components/result_table.slint";
import { StatusBar }       from "components/status_bar.slint";

// UiState is defined here (root file) so that Slint generates Rust bindings for it.
// Sub-components that need global state receive properties bound from UiState below.
export global UiState {
    // ── Core UI state ─────────────────────────────────────────────────────────
    in-out property <bool>   is-loading:        false;
    in-out property <string> status-message:    "";
    in-out property <string> error-message:     "";
    in-out property <string> status-connection: @tr("Not connected");

    // ── Appearance ────────────────────────────────────────────────────────────
    in-out property <string> font-family: "JetBrains Mono";
    in-out property <int>    font-size:   14;  // logical pixels

    // ── Editor state ──────────────────────────────────────────────────────────
    in-out property <string> editor-text: "";

    // ── Editor helpers (implemented in Rust, callable in property bindings) ───
    pure callback count-lines(string) -> int;
    /// Returns the 0-based line index at the given UTF-8 byte offset.
    pure callback cursor-line(string, int) -> int;
    /// Moves cursor by delta lines (-1=up, +1=down) from byte offset, returns new offset.
    pure callback move-cursor-line(string, int, int) -> int;

    // ── Query result state ────────────────────────────────────────────────────
    in-out property <[string]>  result-columns:   [];
    in-out property <[RowData]> result-rows:      [];
    in-out property <int>       result-row-count: 0;

    // ── Connection list (sidebar) ─────────────────────────────────────────────
    in-out property <[ConnectionEntry]> connection-list:      [];
    in-out property <string>            active-connection-id: "";

    // ── Connection form state ─────────────────────────────────────────────────
    in-out property <bool>   show-connection-form: false;
    in-out property <int>    form-tab-index:   0;   // 0 = conn-string, 1 = fields
    in-out property <int>    form-db-type:     0;   // 0 = PostgreSQL, 1 = MySQL, 2 = SQLite
    in-out property <string> form-name:        "";
    in-out property <string> form-conn-string: "";
    in-out property <string> form-host:        "";
    in-out property <string> form-port:        "";
    in-out property <string> form-user:        "";
    in-out property <string> form-password:    "";
    in-out property <string> form-database:    "";
    in-out property <string> form-status:      "";
    in-out property <bool>   form-testing:     false;

    // ── UI → Controller callbacks ─────────────────────────────────────────────
    callback run-query(string);
    callback cancel-query();
    callback connect(string);
    callback disconnect(string);

    // ── Connection management callbacks ───────────────────────────────────────
    callback open-connection-form();
    callback close-connection-form();
    // Builds DbConnection from form fields and sends Command::Connect.
    // Closes the form on success; shows error inline on failure.
    callback test-connection();
    // Re-connects an existing saved connection by id.
    callback switch-connection(string);
}

export component AppWindow inherits Window {
    title: "wellfeather";
    // Explicit width/height fix root.width/root.height as constants, which are then
    // used in arithmetic expressions below to position all children absolutely.
    // VerticalLayout + vertical-stretch proved unreliable when height: parent.height
    // is set on a layout — the stretch distribution ignores the explicit height and
    // falls back to preferred-height (~61px). Absolute positioning with arithmetic
    // avoids all layout-engine ambiguity.
    width:  1280px;
    height: 800px;

    // ── Sidebar ───────────────────────────────────────────────────────────────
    Sidebar {
        x: 0;
        y: 0;
        width:  220px;
        height: root.height - 24px;
        connections: UiState.connection-list;
        switch-connection(id) => { UiState.switch-connection(id); }
        add-connection => { UiState.open-connection-form(); }
    }

    // ── SQL editor — top 55% of content area ─────────────────────────────────
    Editor {
        x: 220px;
        y: 0;
        width:  root.width  - 220px;
        height: (root.height - 24px) * 0.55;
        text         <=> UiState.editor-text;
        font-family:     UiState.font-family;
        font-size-px:    UiState.font-size;
        line-count:      UiState.count-lines(UiState.editor-text);
        cursor-line(text, pos) => { UiState.cursor-line(text, pos); }
        move-cursor-line(text, pos, delta) => { UiState.move-cursor-line(text, pos, delta); }
    }

    // ── Result table — bottom 45% of content area ─────────────────────────────
    ResultTable {
        x: 220px;
        y: (root.height - 24px) * 0.55;
        width:  root.width  - 220px;
        height: (root.height - 24px) * 0.45;
        columns:    UiState.result-columns;
        rows:       UiState.result-rows;
        row-count:  UiState.result-row-count;
        is-loading: UiState.is-loading;
    }

    // ── Status bar ────────────────────────────────────────────────────────────
    StatusBar {
        x: 0;
        y: root.height - 24px;
        width:  root.width;
        height: 24px;
        connection-text: UiState.status-connection;
    }

    // ── Connection form modal overlay ─────────────────────────────────────────
    // Rendered last so it appears above everything else.
    if UiState.show-connection-form: Rectangle {
        x: 0;
        y: 0;
        width:  root.width;
        height: root.height;
        background: #00000088;

        ConnectionForm {
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;

            tab-index   <=> UiState.form-tab-index;
            db-type     <=> UiState.form-db-type;
            name        <=> UiState.form-name;
            conn-string <=> UiState.form-conn-string;
            host        <=> UiState.form-host;
            port        <=> UiState.form-port;
            user        <=> UiState.form-user;
            password    <=> UiState.form-password;
            database    <=> UiState.form-database;
            status      <=> UiState.form-status;
            testing     <=> UiState.form-testing;

            cancel => { UiState.close-connection-form(); }
            test-connection => { UiState.test-connection(); }
        }
    }
}
